# Google AI Platform (Required)
GOOGLE_API_KEY="AIzaSyYourGeminiApiKeyHere..."
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# Application Config
DEBUG=True
HOSPITAL_NAME="City Care Hospital"
HOSPITAL_PHONE="+1-800-ABC-HOSP"

# Exotel (Optional: for live inbound phone calls)
EXOTEL_ACCOUNT_SID="your_exotel_sid..."
EXOTEL_API_KEY="your_exotel_api_key..."
EXOTEL_API_TOKEN="your_exotel_api_token..."
EXOTEL_PHONE_NUMBER="+1234567890"

# Database Link (handled automatically in Docker Compose)
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/hospital_ai"
